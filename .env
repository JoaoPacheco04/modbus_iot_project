# Modbus
MODBUS_HOST=modbus-server
MODBUS_PORT=1502

# MQTT broker (mosquitto externo)
MQTT_HOST=edgex-mosquitto
MQTT_PORT=1884
MQTT_TOPIC=edgex/factory/sensors

# Intervalo de leitura (segundos)
INTERVALO=5

# EdgeX / Postgres
POSTGRES_PASSWORD=postgres

# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=password123
INFLUXDB_ORG=edgex-org
INFLUXDB_BUCKET=factory
INFLUXDB_TOKEN=edgex-influx-token-2024
